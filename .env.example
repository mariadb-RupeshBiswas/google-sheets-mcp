# Google Sheets MCP - Integration Test Configuration
# Copy this file to .env and fill in your test spreadsheet ID

# Required for integration tests
# Set to "1" to enable integration tests
INTEGRATION=1

# Your test spreadsheet ID (not the full URL, just the ID)
# Example: TEST_SPREADSHEET_ID=1ABC...XYZ
TEST_SPREADSHEET_ID=your_test_spreadsheet_id

# The spreadsheet should have at least one sheet with data for comprehensive testing
