{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 Run MCP Server (stdio)",
      "detail": "Start the MCP server in stdio mode for editors and MCP clients.",
      "type": "shell",
      "command": "uv",
      "args": ["run", "g-sheet-mcp"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "🌐 Run MCP Server (HTTP)",
      "detail": "Start the streamable HTTP server at http://127.0.0.1:8000/mcp.",
      "type": "shell",
      "command": "uv",
      "args": ["run", "g-sheet-mcp", "--http"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "🐞 Run MCP Server (Debug)",
      "detail": "Start the server with verbose logging for troubleshooting.",
      "type": "shell",
      "command": "uv",
      "args": ["run", "g-sheet-mcp", "--debug"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "🧪 Run Unit Tests",
      "detail": "Run fast local tests without live Google API calls.",
      "type": "shell",
      "command": "uv",
      "args": ["run", "pytest", "tests/", "--ignore=tests/test_integration.py", "-v"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "🧪 Run Integration Tests",
      "detail": "Run live Google Sheets tests with ADC and a test spreadsheet ID.",
      "type": "shell",
      "command": "uv",
      "args": ["run", "pytest", "tests/test_integration.py", "-v"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      },
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "options": {
        "env": {
          "INTEGRATION": "1",
          "TEST_SPREADSHEET_ID": "${input:testSpreadsheetId}"
        }
      }
    },
    {
      "label": "🧪 Run All Tests",
      "detail": "Run unit and integration tests together.",
      "type": "shell",
      "command": "uv",
      "args": ["run", "pytest", "tests/", "-v"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      },
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "options": {
        "env": {
          "INTEGRATION": "1",
          "TEST_SPREADSHEET_ID": "${input:testSpreadsheetId}"
        }
      }
    },
    {
      "label": "📊 Run Tests with Coverage",
      "detail": "Run unit tests with terminal and HTML coverage output.",
      "type": "shell",
      "command": "uv",
      "args": [
        "run",
        "pytest",
        "tests/",
        "--ignore=tests/test_integration.py",
        "--cov=src/g_sheet_mcp",
        "--cov-report=term-missing",
        "--cov-report=html"
      ],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      },
      "group": {
        "kind": "test",
        "isDefault": false
      }
    },
    {
      "label": "🔎 Lint (Ruff)",
      "detail": "Check code style, imports, and common Python issues.",
      "type": "shell",
      "command": "uv",
      "args": ["run", "ruff", "check", "src/", "tests/"],
      "problemMatcher": {
        "owner": "python",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+):(\\d+):(\\d+):\\s+(\\w+):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "🛠️ Lint & Fix (Ruff)",
      "detail": "Apply safe Ruff auto-fixes where possible.",
      "type": "shell",
      "command": "uv",
      "args": ["run", "ruff", "check", "--fix", "src/", "tests/"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "🧠 Type Check (Mypy)",
      "detail": "Run static type checks against src/.",
      "type": "shell",
      "command": "uv",
      "args": ["run", "mypy", "src/"],
      "problemMatcher": {
        "owner": "python",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+):(\\d+):\\s+(error|warning|note):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "severity": 3,
          "message": 4
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "📦 Sync Dependencies",
      "detail": "Install or update locked dependencies with dev extras.",
      "type": "shell",
      "command": "uv",
      "args": ["sync", "--extra", "dev"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      }
    },
    {
      "label": "� Lock Dependencies",
      "detail": "Refresh uv.lock after dependency changes.",
      "type": "shell",
      "command": "uv",
      "args": ["lock"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      }
    },
    {
      "label": "�📦 Build Package",
      "detail": "Build wheel and sdist artifacts for local verification or publishing.",
      "type": "shell",
      "command": "uv",
      "args": ["build"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      }
    },
    {
      "label": "🔑 Authenticate Google (ADC)",
      "detail": "Open the Google Cloud login flow and refresh Application Default Credentials.",
      "type": "shell",
      "command": "gcloud",
      "args": ["auth", "login", "--enable-gdrive-access", "--update-adc"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "✅ Full CI Check",
      "detail": "Run lint, type check, and unit tests in sequence.",
      "dependsOrder": "sequence",
      "dependsOn": ["🔎 Lint (Ruff)", "🧠 Type Check (Mypy)", "🧪 Run Unit Tests"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ],
  "inputs": [
    {
      "id": "testSpreadsheetId",
      "type": "promptString",
      "description": "🔑 Google Sheets spreadsheet ID for live integration tests",
      "default": "example_test_spreadsheet_id"
    }
  ]
}
