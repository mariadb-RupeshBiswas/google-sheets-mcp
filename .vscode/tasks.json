{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run MCP Server (stdio)",
      "type": "shell",
      "command": "uv",
      "args": ["run", "g-sheet-mcp"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Run MCP Server (HTTP)",
      "type": "shell",
      "command": "uv",
      "args": ["run", "g-sheet-mcp", "--http"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Run MCP Server (Debug)",
      "type": "shell",
      "command": "uv",
      "args": ["run", "g-sheet-mcp", "--debug"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Run Unit Tests",
      "type": "shell",
      "command": "uv",
      "args": ["run", "pytest", "tests/", "--ignore=tests/test_integration.py", "-v"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Run Integration Tests",
      "type": "shell",
      "command": "uv",
      "args": ["run", "pytest", "tests/test_integration.py", "-v"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      },
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "options": {
        "env": {
          "INTEGRATION": "1",
          "TEST_SPREADSHEET_ID": "${input:testSpreadsheetId}"
        }
      }
    },
    {
      "label": "Run All Tests",
      "type": "shell",
      "command": "uv",
      "args": ["run", "pytest", "tests/", "-v"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      },
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "options": {
        "env": {
          "INTEGRATION": "1",
          "TEST_SPREADSHEET_ID": "${input:testSpreadsheetId}"
        }
      }
    },
    {
      "label": "Run Tests with Coverage",
      "type": "shell",
      "command": "uv",
      "args": [
        "run",
        "pytest",
        "tests/",
        "--ignore=tests/test_integration.py",
        "--cov=src/g_sheet_mcp",
        "--cov-report=term-missing",
        "--cov-report=html"
      ],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      },
      "group": {
        "kind": "test",
        "isDefault": false
      }
    },
    {
      "label": "Lint (Ruff)",
      "type": "shell",
      "command": "uv",
      "args": ["run", "ruff", "check", "src/", "tests/"],
      "problemMatcher": {
        "owner": "python",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+):(\\d+):(\\d+):\\s+(\\w+):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Lint & Fix (Ruff)",
      "type": "shell",
      "command": "uv",
      "args": ["run", "ruff", "check", "--fix", "src/", "tests/"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Type Check (Mypy)",
      "type": "shell",
      "command": "uv",
      "args": ["run", "mypy", "src/"],
      "problemMatcher": {
        "owner": "python",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+):(\\d+):\\s+(error|warning|note):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "severity": 3,
          "message": 4
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Sync Dependencies",
      "type": "shell",
      "command": "uv",
      "args": ["sync", "--extra", "dev"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      }
    },
    {
      "label": "Build Package",
      "type": "shell",
      "command": "uv",
      "args": ["build"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      }
    },
    {
      "label": "Authenticate Google (ADC)",
      "type": "shell",
      "command": "gcloud",
      "args": ["auth", "login", "--enable-gdrive-access", "--update-adc"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "Full CI Check",
      "dependsOrder": "sequence",
      "dependsOn": ["Lint (Ruff)", "Type Check (Mypy)", "Run Unit Tests"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ],
  "inputs": [
    {
      "id": "testSpreadsheetId",
      "type": "promptString",
      "description": "Google Sheets spreadsheet ID for live integration tests",
      "default": "your_spreadsheet_id"
    }
  ]
}
